<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Informe de Actividad - {{ agent.firstName }} {{ agent.lastName }}</title>
    <style>
        body { font-family: 'Helvetica', sans-serif; color: #333; margin: 20px; }
        .header { text-align: center; border-bottom: 2px solid #8e2de2; padding-bottom: 10px; margin-bottom: 30px; }
        .header h1 { margin: 0; color: #4a00e0; font-size: 24px; }
        .header p { margin: 5px 0; color: #666; }
        
        .agent-info { margin-bottom: 30px; background: #f9f9f9; padding: 15px; border-radius: 8px; }
        .agent-info table { width: 100%; }
        .agent-info td { padding: 5px; }
        .label { font-weight: bold; color: #555; }
        
        table.data-table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        table.data-table th, table.data-table td { border: 1px solid #ddd; padding: 10px; text-align: left; }
        table.data-table th { background-color: #f2f2f2; font-weight: bold; }
        
        .segment-tag { display: inline-block; background: #e3f2fd; color: #1565c0; padding: 2px 6px; border-radius: 4px; margin-right: 5px; font-size: 10px; }
        .total-row { font-weight: bold; background: #fdfdfd; }
        .summary-box { margin-top: 40px; text-align: right; border-top: 1px solid #eee; padding-top: 20px; }
        .summary-box .grand-total { font-size: 18px; font-weight: 900; color: #8e2de2; }
    </style>
</head>
<body>
    <div class="header">
        <h1>REGISTRO DE ACTIVIDAD MENSUAL</h1>
        <p>Mes: {{ monthName }} {{ year }}</p>
    </div>

    <div class="agent-info">
        <table>
            <tr>
                <td class="label">Agente:</td>
                <td>{{ agent.firstName }} {{ agent.lastName }}</td>
                <td class="label">Email:</td>
                <td>{{ agent.email }}</td>
            </tr>
            <tr>
                <td class="label">Fecha Informe:</td>
                <td>{{ "now"|date("d/m/Y H:i") }}</td>
                <td class="label">Total Horas Mes:</td>
                <td style="font-weight: bold; color: #4a00e0;">{{ (totalMinutes / 60)|number_format(2) }} h</td>
            </tr>
        </table>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>Día</th>
                <th>Tramos de Conexión</th>
                <th>Minutos App</th>
                <th>Horas Trabajo (Tickets)</th>
            </tr>
        </thead>
        <tbody>
            {% for day, data in dailyStats %}
            <tr>
                <td>{{ day }}</td>
                <td>
                    {% for segment in data.segments %}
                        <span class="segment-tag">{{ segment.start|slice(0, 5) }} - {{ segment.end|slice(0, 5) }}</span>
                    {% endfor %}
                </td>
                <td style="text-align: right;">{{ data.totalMinutes }} min</td>
                <td style="text-align: right;">{{ (data.workMinutes / 60)|number_format(1) }} h</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="4" style="text-align: center;">No hay registros de actividad para este periodo.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="summary-box">
        <p>Resumen del Mes: <span class="grand-total">{{ (totalMinutes / 60)|number_format(2) }} Horas de Conexión Totales</span></p>
        <p style="font-size: 11px; color: #999;">* Este informe detalla el tiempo que el agente ha estado activo en la interfaz web de HelpDesk.</p>
    </div>
</body>
</html>
